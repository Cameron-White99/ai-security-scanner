# Application
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_security_scanner

# LLM Fallback (Anthropic)
# Leave empty to disable LLM fallback
ANTHROPIC_API_KEY=

# Detection
# Confidence below this triggers LLM fallback (0.0–1.0)
LLM_FALLBACK_THRESHOLD=0.6
